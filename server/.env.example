# ==========================================
# SUPABASE PLATFORM KEYS
# ==========================================
# Client URL for frontend data access
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Client Anon Key
VITE_SUPABASE_ANON_KEY=your-anon-key
# Administrative Service Role Key for backend routing/automation (KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# STRIPE INTEGRATION KEYS
# ==========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GENERATED VIA setup-stripe.js
STRIPE_PRICE_MONTHLY=price_12345
STRIPE_PRICE_YEARLY=price_67890

# BASE ALGORITHMIC VALUES
PRIZE_CONTRIBUTION_AMOUNT=10.00

# ==========================================
# ENVIRONMENT CONFIG
# ==========================================
PORT=5000
CLIENT_URL=http://localhost:5173
